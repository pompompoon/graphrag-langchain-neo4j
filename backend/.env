# ============================================================
# GraphRAG Local LLM - 環境設定
# ============================================================

# --- LLMプロバイダ ---
PROVIDER=ollama

# --- ストレージ ---
# "file"  = ファイルベース（graphml + hnswlib + json）
# "neo4j" = Neo4j（グラフ + ベクトル一元管理）
STORAGE=neo4j

# --- Ollama設定 ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EXTRACT_MODEL=qwen2.5:7b

# --- Gemini設定（PROVIDER=gemini の場合）---
# APIキー取得: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EXTRACT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=models/gemini-embedding-001

# --- Neo4j設定（STORAGE=neo4j の場合）---
# Neo4j Desktop: bolt://localhost:7687
# Neo4j Docker:  bolt://localhost:7687
# Neo4j Aura:    neo4j+s://xxxxx.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
